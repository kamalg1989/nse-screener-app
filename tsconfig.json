{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "jest",
      "@testing-library/jest-dom"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "app/*"
      ],
      "@screens/*": [
        "app/screens/*"
      ],
      "@components/*": [
        "app/components/*"
      ],
      "@screener/*": [
        "app/screener/*"
      ],
      "@db/*": [
        "app/db/*"
      ],
      "@utils/*": [
        "app/utils/*"
      ],
      "@hooks/*": [
        "app/hooks/*"
      ]
    }
  },
  "include": [
    "app",
    "__tests__"
  ],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ],
  "extends": "expo/tsconfig.base"
}
