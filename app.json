"android.permission.INTERNET",
"android.permission.ACCESS_NETWORK_STATE"
],
"package": "com.kamalg.nsescreen"
},
"web": {
"favicon": "./assets/images/favicon.png"
},
"owner": "kamalg89",
"runtimeVersion": {
"policy": "appVersion"
},
"updates": {
"enabled": false
},
"extra": {
"eas": {
"projectId": "3fd74125-4644-40e9-9282-3267d7dcf7ab"
}
}
}
